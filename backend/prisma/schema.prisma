generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApplicationStatus {
  uploaded
  processing
  completed
  failed
}

enum PipelineStage {
  extract
  submodel_a
  submodel_b
  submodel_c
  main_eval
}

enum PipelineRunStatus {
  pending
  running
  done
  failed
}

enum ImageType {
  certificate
  profile_photo
  logo
  other
}

enum Recommendation {
  strong_match
  good_match
  reject
}

model JobDescription {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  description  String
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id           String            @id @default(uuid())
  jobId        String
  job          JobDescription    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name         String
  email        String
  resumePath   String
  status       ApplicationStatus @default(uploaded)
  errorStage   String?
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  pipelineRuns    PipelineRun[]
  extractedImages ExtractedImage[]
  evaluation      Evaluation?
}

model PipelineRun {
  id               String            @id @default(uuid())
  applicationId    String
  application      Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage            PipelineStage
  status           PipelineRunStatus @default(pending)
  rawOutput        Json?
  structuredOutput Json?
  error            String?
  startedAt        DateTime?
  finishedAt       DateTime?

  @@index([applicationId])
}

model ExtractedImage {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  imagePath     String
  imageType     ImageType?
  details       Json?

  @@index([applicationId])
}

model Evaluation {
  id             String         @id @default(uuid())
  applicationId  String         @unique
  application    Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  matchScore     Int
  recommendation Recommendation
  strengths      Json
  gaps           Json
  rawLlmJson     Json
  createdAt      DateTime       @default(now())
}
