# --- Postgres ---
POSTGRES_USER=ats
POSTGRES_PASSWORD=ats
POSTGRES_DB=ats
DATABASE_URL=postgresql://ats:ats@db:5432/ats?schema=public

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Services ---
PARSER_URL=http://parser:8000
API_PORT=4000

# --- Admin auth (POC: single static password) ---
ADMIN_PASSWORD=changeme
ADMIN_TOKEN_SECRET=dev-secret-change-me

# --- Gemini (comma-separated pool of free-tier keys from different accounts) ---
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RPM=10
GEMINI_RPD=250

# --- Uploads ---
MAX_UPLOAD_MB=10
DATA_DIR=/data
# Max certificate vision calls per resume (the only per-image AI cost).
MAX_VISION_IMAGES=2

# --- Inbound email (Mailpit) ---
# REST API the API service uses to fetch messages + attachments.
MAILPIT_API_URL=http://mailpit:8025
# Shared secret. Must equal the password in MP_WEBHOOK_URL below.
EMAIL_WEBHOOK_SECRET=dev-email-secret-change-me
# Mailpit posts each received message to this URL (user:password@host).
MP_WEBHOOK_URL=http://ats:dev-email-secret-change-me@api:4000/api/webhook/email

# --- Frontend ---
VITE_API_BASE=http://localhost:4000
